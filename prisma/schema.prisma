generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
//  ENUMS
// ==========================================
enum Role {
  ADMIN
  OPERATOR
  INVESTOR
  ASSOCIATE
}

enum UserStatus {
  PENDING_ONBOARDING
  PENDING_REVIEW
  ACTIVE
}

// ==========================================
//  MODEL: USUÁRIO (User)
// ==========================================
model User {
  id                    String       @id @default(auto()) @map("_id") @db.ObjectId
  auth0UserId           String       @unique
  email                 String       @unique
  name                  String
  role                  Role         @default(INVESTOR)
  status                UserStatus?  @default(PENDING_ONBOARDING)

  cpfOrCnpj             String?
  rg                    String?
  birthDate             DateTime?
  gender                String?
  cellPhone             String?
  phone                 String?
  profession            String?
  contactPreference     String?
  infoEmail             String?

  nationality           String?
  maritalStatus         String?

  // Endereços
  residentialCep        String?
  residentialStreet     String?
  residentialNumber     String?
  residentialComplement String?
  residentialNeighborhood String?
  residentialCity       String?
  residentialState      String?

  commercialCep         String?
  commercialStreet      String?
  commercialNumber      String?
  commercialComplement  String?
  commercialNeighborhood String?
  commercialCity        String?
  commercialState       String?

  correspondenceAddress String?

  // Arquivos
  pictureUrl            String?
  profilePictureUrl     String?
  personalDocumentUrls  String[]     @default([])

  // Integração
  legalOneContactId     Int?         

  // Indicação e Associação
  indication            String?
  referredById          String?      @db.ObjectId
  referredBy            User?        @relation("UserReferral", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals             User[]       @relation("UserReferral")
  associateSequence     Int?

  // Relacionamentos Inversos
  investments           Investment[]
  associateInvestments  Investment[] @relation("AssociateInvestment")

  // CORREÇÃO: Relação reversa para o associado principal do processo
  associateAssets       CreditAsset[] @relation("CreditAssetAssociate")

  // Solicitações de alteração de perfil
  profileChangeRequests UserProfileChangeRequest[] @relation("UserProfileChanges")

  // CORREÇÃO: Nulos permitidos
  createdAt             DateTime?    @default(now())
  updatedAt             DateTime?    @updatedAt
  approvedAt            DateTime?

  @@index([status])
  @@index([referredById])
}

// ==========================================
//  MODEL: PASTA DE PROCESSOS (ProcessFolder)
// ==========================================
model ProcessFolder {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  folderCode  String        @unique
  description String?
  assets      CreditAsset[]

  // CORREÇÃO: Nulos permitidos
  createdAt   DateTime?     @default(now())
  updatedAt   DateTime?     @updatedAt
}

// ==========================================
//  MODEL: ATIVO JUDICIAL (CreditAsset)
// ==========================================
model CreditAsset {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  processNumber        String
  nickname             String?
  otherParty           String?
  originalCreditor     String
  origemProcesso       String

  legalOneId           Int           @unique
  legalOneType         String?
  
  originalValue        Float
  acquisitionValue     Float
  currentValue         Float
  acquisitionDate      DateTime

  updateIndexType      String
  contractualIndexRate Float?

  status               String        @default("PENDING_ENRICHMENT")
  
  strategyText         String?

  folderId             String?       @db.ObjectId
  folder               ProcessFolder? @relation(fields: [folderId], references: [id])

  associateId          String?       @db.ObjectId
  // CORREÇÃO: Mapeamento explícito da relação do Associado do Processo
  associate            User?         @relation("CreditAssetAssociate", fields: [associateId], references: [id])

  investors            Investment[]
  updates              AssetUpdate[]
  documents            Document[]

  // CORREÇÃO: Nulos permitidos
  createdAt            DateTime?     @default(now())
  updatedAt            DateTime?     @updatedAt

  @@index([status])
  @@index([folderId])
  @@index([associateId])
}

// ==========================================
//  MODEL: INVESTIMENTOS (Investment)
// ==========================================
model Investment {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  investorShare   Float
  mazzotiniShare  Float

  userId          String      @db.ObjectId
  creditAssetId   String      @db.ObjectId

  associateId     String?     @db.ObjectId
  acquisitionDate DateTime?

  user            User        @relation(fields: [userId], references: [id])
  asset           CreditAsset @relation(fields: [creditAssetId], references: [id]) 
  associate       User?       @relation("AssociateInvestment", fields: [associateId], references: [id])

  documents       String[]    @default([])

  // CORREÇÃO: Nulos permitidos
  createdAt       DateTime?   @default(now())
  updatedAt       DateTime?   @updatedAt

  @@index([userId])
  @@index([creditAssetId])
}

// ==========================================
//  MODEL: ANDAMENTOS (AssetUpdate)
// ==========================================
model AssetUpdate {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  date             DateTime
  description      String
  updatedValue     Float
  source           String

  assetId          String      @db.ObjectId
  asset            CreditAsset @relation(fields: [assetId], references: [id])

  legalOneUpdateId Int?

  // CORREÇÃO: Nulos permitidos
  createdAt        DateTime?   @default(now())
  updatedAt        DateTime?   @updatedAt

  @@index([assetId])
}

// ==========================================
//  MODEL: DOCUMENTOS LEGAIS (Document)
// ==========================================
model Document {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  url                String
  category           String

  assetId            String      @db.ObjectId
  asset              CreditAsset @relation(fields: [assetId], references: [id])

  legalOneDocumentId Int?

  // CORREÇÃO: Nulos permitidos
  createdAt          DateTime?   @default(now())
  updatedAt          DateTime?   @updatedAt

  @@index([assetId])
}

// ==========================================
//  MODEL: SOLICITAÇÃO DE ALTERAÇÃO DE PERFIL
// ==========================================
model UserProfileChangeRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation("UserProfileChanges", fields: [userId], references: [id])

  // Snapshot dos campos propostos (JSON livre)
  proposedData Json

  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?

  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  @@index([userId])
  @@index([status])
}

// ==========================================
//  MODEL: HEALTH CHECK LOGS
// ==========================================
model SystemHealthLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  runAt     DateTime @default(now())
  status    String   // "ok" | "degraded" | "error"
  checks    Json     // CheckResult[]
  triggeredBy String @default("cron") // "cron" | "manual"
}

// ==========================================
//  MODEL: NOTIFICAÇÕES (SystemNotification)
// ==========================================
model SystemNotification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  message   String
  type      String   @default("info")
  link      String?

  // CORREÇÃO: Nulos permitidos
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}