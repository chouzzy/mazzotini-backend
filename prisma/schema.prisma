generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
//  ENUMS
// ==========================================
enum Role {
  ADMIN
  OPERATOR
  INVESTOR
  ASSOCIATE
}

enum UserStatus {
  PENDING_ONBOARDING
  PENDING_REVIEW
  ACTIVE
}

// ==========================================
//  MODEL: USUÁRIO (User)
// ==========================================
model User {
  id                    String       @id @default(auto()) @map("_id") @db.ObjectId
  auth0UserId           String       @unique
  email                 String       @unique
  name                  String
  role                  Role         @default(INVESTOR)
  status                UserStatus?  @default(PENDING_ONBOARDING)

  cpfOrCnpj             String?
  rg                    String?
  birthDate             DateTime?
  gender                String?
  cellPhone             String?
  phone                 String?
  profession            String?
  contactPreference     String?
  infoEmail             String?

  nationality           String?
  maritalStatus         String?

  // Endereços
  residentialCep        String?
  residentialStreet     String?
  residentialNumber     String?
  residentialComplement String?
  residentialNeighborhood String?
  residentialCity       String?
  residentialState      String?

  commercialCep         String?
  commercialStreet      String?
  commercialNumber      String?
  commercialComplement  String?
  commercialNeighborhood String?
  commercialCity        String?
  commercialState       String?

  correspondenceAddress String?

  // Arquivos
  pictureUrl            String?
  profilePictureUrl     String?
  personalDocumentUrls  String[]     @default([])

  // Integração
  legalOneContactId     Int?         

  // Indicação e Associação
  indication            String?
  referredById          String?      @db.ObjectId
  referredBy            User?        @relation("UserReferral", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals             User[]       @relation("UserReferral")
  associateSequence     Int?

  // Relacionamentos Inversos
  investments           Investment[]
  associateInvestments  Investment[] @relation("AssociateInvestment")

  // CORREÇÃO: Relação reversa para o associado principal do processo
  associateAssets       CreditAsset[] @relation("CreditAssetAssociate")

  // Solicitações de alteração de perfil
  profileChangeRequests UserProfileChangeRequest[] @relation("UserProfileChanges")

  // Documentos transitórios financeiros (staging)
  stagingDocuments      UserStagingDocument[]

  // Consentimento LGPD
  consentedToTermsAt   DateTime?
  consentedToPrivacyAt DateTime?
  termsVersion         String?

  // CORREÇÃO: Nulos permitidos
  createdAt             DateTime?    @default(now())
  updatedAt             DateTime?    @updatedAt
  approvedAt            DateTime?

  @@index([status])
  @@index([referredById])
}

// ==========================================
//  MODEL: PASTA DE PROCESSOS (ProcessFolder)
// ==========================================
model ProcessFolder {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  folderCode  String        @unique
  description String?
  assets      CreditAsset[]

  // CORREÇÃO: Nulos permitidos
  createdAt   DateTime?     @default(now())
  updatedAt   DateTime?     @updatedAt
}

// ==========================================
//  MODEL: ATIVO JUDICIAL (CreditAsset)
// ==========================================
model CreditAsset {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  processNumber        String
  nickname             String?
  otherParty           String?
  originalCreditor     String
  origemProcesso       String

  legalOneId           Int           @unique
  legalOneType         String?
  
  originalValue        Float
  acquisitionValue     Float
  currentValue         Float
  acquisitionDate      DateTime

  updateIndexType      String
  contractualIndexRate Float?

  status               String        @default("PENDING_ENRICHMENT")
  
  strategyText         String?

  folderId             String?       @db.ObjectId
  folder               ProcessFolder? @relation(fields: [folderId], references: [id])

  associateId          String?       @db.ObjectId
  // CORREÇÃO: Mapeamento explícito da relação do Associado do Processo
  associate            User?         @relation("CreditAssetAssociate", fields: [associateId], references: [id])

  investors            Investment[]
  updates              AssetUpdate[]
  documents            Document[]
  calculationParams    ProcessCalculationParams?

  // CORREÇÃO: Nulos permitidos
  createdAt            DateTime?     @default(now())
  updatedAt            DateTime?     @updatedAt

  @@index([status])
  @@index([folderId])
  @@index([associateId])
}

// ==========================================
//  MODEL: INVESTIMENTOS (Investment)
// ==========================================
model Investment {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  investorShare   Float
  mazzotiniShare  Float

  userId          String      @db.ObjectId
  creditAssetId   String      @db.ObjectId

  associateId     String?     @db.ObjectId
  acquisitionDate DateTime?

  user            User        @relation(fields: [userId], references: [id])
  asset           CreditAsset @relation(fields: [creditAssetId], references: [id]) 
  associate       User?       @relation("AssociateInvestment", fields: [associateId], references: [id])

  documents       String[]    @default([])

  // CORREÇÃO: Nulos permitidos
  createdAt       DateTime?   @default(now())
  updatedAt       DateTime?   @updatedAt

  @@index([userId])
  @@index([creditAssetId])
}

// ==========================================
//  MODEL: ANDAMENTOS (AssetUpdate)
// ==========================================
model AssetUpdate {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  date             DateTime
  description      String
  updatedValue     Float
  source           String

  assetId          String      @db.ObjectId
  asset            CreditAsset @relation(fields: [assetId], references: [id])

  legalOneUpdateId Int?

  // CORREÇÃO: Nulos permitidos
  createdAt        DateTime?   @default(now())
  updatedAt        DateTime?   @updatedAt

  @@index([assetId])
}

// ==========================================
//  MODEL: DOCUMENTOS DO PROCESSO (Document)
// ==========================================
model Document {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  url                String
  fileKey            String?
  mimeType           String?

  // Seção: JURIDICO | PRIVADO_FINANCEIRO | PROCESSUAL
  section            String      @default("JURIDICO")
  // Categoria dentro da seção (ex: TERMO_CESSAO, COMPROVANTE, etc.)
  category           String

  // Origem: LEGAL_ONE | MANUAL | CLIENTE
  sourceType         String      @default("LEGAL_ONE")
  sourceStagingDocId String?
  uploadedByUserId   String?     @db.ObjectId

  // Para docs de PRIVADO_FINANCEIRO: scoped ao cliente específico
  investorUserId     String?     @db.ObjectId

  // Processo vinculado — opcional para docs de contrato de honorário (nível cliente)
  assetId            String?     @db.ObjectId
  asset              CreditAsset? @relation(fields: [assetId], references: [id])

  legalOneDocumentId Int?
  // ID do contrato de honorário no Legal One (origem para docs de cliente)
  legalOneServiceId  Int?

  createdAt          DateTime?   @default(now())
  updatedAt          DateTime?   @updatedAt

  @@index([assetId])
  @@index([section])
  @@index([investorUserId])
}

// ==========================================
//  MODEL: DOCUMENTOS TRANSITÓRIOS (UserStagingDocument)
// ==========================================
model UserStagingDocument {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  user         User      @relation(fields: [userId], references: [id])

  fileName     String
  fileUrl      String
  fileKey      String
  mimeType     String    @default("application/octet-stream")
  category     String?   // categoria sugerida pelo cliente (ex: COMPROVANTE)

  // PENDING | ATTACHED
  status       String    @default("PENDING")

  attachedToAssetId    String?   @db.ObjectId
  attachedToAssetName  String?
  attachedCategory     String?
  attachedAt           DateTime?
  attachedByUserId     String?   @db.ObjectId

  createdAt    DateTime? @default(now())

  @@index([userId])
  @@index([status])
}

// ==========================================
//  MODEL: SOLICITAÇÃO DE ALTERAÇÃO DE PERFIL
// ==========================================
model UserProfileChangeRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation("UserProfileChanges", fields: [userId], references: [id])

  // Snapshot dos campos propostos (JSON livre)
  proposedData Json

  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?

  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  @@index([userId])
  @@index([status])
}

// ==========================================
//  MODEL: LOG DE IMPORTAÇÃO
// ==========================================
model ImportLog {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  triggeredAt    DateTime  @default(now())
  triggeredBy    String    @default("cron")  // "cron" | auth0UserId
  since          DateTime?
  importedCount  Int       @default(0)
  skippedCount   Int       @default(0)
  errorCount     Int       @default(0)
  status         String    @default("running") // "running" | "completed" | "failed"
  finishedAt     DateTime?
  durationMs     Int?
  errorMessage   String?
}

// ==========================================
//  MODEL: CONFIGURAÇÕES DO SISTEMA
// ==========================================
model SystemSettings {
  id                          String   @id @default(auto()) @map("_id") @db.ObjectId
  autoImportAppeals           Boolean  @default(true)
  autoImportProceduralIssues  Boolean  @default(true)
  updatedAt                   DateTime @updatedAt
  updatedBy                   String?
}

// ==========================================
//  MODEL: SÉRIES DE ÍNDICES JUDICIAIS
// ==========================================
model IndexSeries {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  // "TJSP_LEI14905" | "IPCA_E" | "INPC" | "IPCA15" | "SELIC"
  indexName       String
  year            Int
  month           Int
  monthlyRate     Float    // variação mensal em % (ex: 0.52 = 0,52%)
  accumulatedValue Float?  // valor acumulado da tabela oficial (ex: drcalc)
  createdAt       DateTime @default(now())

  @@unique([indexName, year, month])
}

// ==========================================
//  MODEL: PARÂMETROS DE CÁLCULO DO PROCESSO
// ==========================================
model ProcessCalculationParams {
  id      String      @id @default(auto()) @map("_id") @db.ObjectId
  assetId String      @unique @db.ObjectId
  asset   CreditAsset @relation(fields: [assetId], references: [id])

  // Índice de correção monetária
  correctionIndex     String   @default("TJSP_LEI14905")

  // Juros moratórios
  moratoryMode        String   @default("TAXA_LEGAL") // "TAXA_LEGAL" | "PERSONALIZADO"
  moratoryRate        Float    @default(1)
  moratoryRateUnit    String   @default("AM")         // "AM" | "AA"
  moratoryType        String   @default("SIMPLES")    // "SIMPLES" | "COMPOSTO"
  moratoryStartDate   DateTime?

  // Juros compensatórios
  compensatoryRate      Float     @default(0)
  compensatoryRateUnit  String    @default("AM")      // "AM" | "AA"
  compensatoryType      String    @default("SIMPLES")
  compensatoryStartDate DateTime?

  // Multa sobre o valor corrigido (diferente da Art.523)
  multaPercentage     Float    @default(0)

  // Honorários e multa Art.523
  feesMode            String   @default("PERCENTUAL") // "PERCENTUAL" | "FIXO"
  feesFixedValue      Float    @default(0)
  feesPercentage      Float    @default(0)
  penaltyPercentage   Float    @default(0)
  feesOnPenalty       Boolean  @default(false)

  // Parcelas do valor base: [{baseValue, baseDate, description}]
  installments        Json     @default("[]")

  // Resultado do último cálculo
  lastCalculatedValue Float?
  lastCalculatedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
//  MODEL: LOG DE CÁLCULO
// ==========================================
model CalculationLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  assetId      String   @db.ObjectId

  calculatedAt   DateTime @default(now())
  calculatedBy   String   @default("cron")   // "cron" | auth0UserId
  referenceMonth Int
  referenceYear  Int

  baseTotal            Float
  correctedValue       Float
  moratoryInterest     Float
  compensatoryInterest Float  @default(0)
  feesValue            Float  @default(0)
  penaltyValue         Float  @default(0)
  totalValue           Float

  // Detalhamento mês a mês (JSON)
  breakdown Json

  // Snapshot dos parâmetros usados neste cálculo (para reabertura/edição)
  paramsSnapshot Json?

  @@index([assetId])
  @@index([calculatedAt])
}

// ==========================================
//  MODEL: HEALTH CHECK LOGS
// ==========================================
model SystemHealthLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  runAt     DateTime @default(now())
  status    String   // "ok" | "degraded" | "error"
  checks    Json     // CheckResult[]
  triggeredBy String @default("cron") // "cron" | "manual"
}

// ==========================================
//  MODEL: NOTIFICAÇÕES (SystemNotification)
// ==========================================
model SystemNotification {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  message          String
  type             String   @default("info")
  link             String?
  notificationType String   @default("GENERAL")
  relatedEntityId  String?
  relatedEntityType String?
  relatedEntityName String?
  readBy           String[] @default([])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}